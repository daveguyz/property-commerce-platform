# =============================================
# StaySphere AOS - Environment Variables
# Copy this file to .env and fill in values
# =============================================

# JWT (generate with: openssl rand -base64 64)
JWT_SECRET=replace_with_your_base64_encoded_256bit_secret

# Stripe
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key

# Shopify
SHOPIFY_STORE_URL=https://your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_your_access_token
SHOPIFY_STOREFRONT_TOKEN=your_storefront_token
SHOPIFY_WEBHOOK_SECRET=your_webhook_hmac_secret

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your_app_password

# Twilio SMS + WhatsApp
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+264xxxxxxxxx
TWILIO_WHATSAPP_NUMBER=+14155238886

# Redis (optional password override)
REDIS_PASSWORD=redis_secret

# Eureka auth
EUREKA_USER=eureka
EUREKA_PASSWORD=eureka_secret

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=grafana_secret
# ── Auction OS ─────────────────────────────────────────────
# Mux Video (livestream)
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
STRIPE_KYC_WEBHOOK_SECRET=whsec_kyc_placeholder

# Auction service DB
AUCTION_DB_URL=jdbc:postgresql://db-auction:5432/staysphere_auction

# ── Shopify App OAuth (for app store listing) ─────────────────
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_OAUTH_REDIRECT_URI=https://app.staysphere.com/oauth/shopify/callback
APP_PUBLIC_URL=https://app.staysphere.com

# ── Theme provisioning ────────────────────────────────────────
# Set to the URL where your Spring Boot API gateway is deployed
# Injected into settings_data.json during provisioning
API_GATEWAY_URL=https://api.staysphere.com
